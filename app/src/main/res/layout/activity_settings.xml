<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurface"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="设置"
        android:elevation="2dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Group 1: Connection -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="连接"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="8dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginBottom="12dp" />

            <!-- Server Address List Container -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="服务器地址"
                android:textSize="16sp"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/serverAddressList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/addAddressBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="+ 添加地址"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="#333333" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginBottom="12dp"
                android:layout_marginTop="4dp" />

            <!-- Auto Select Switch -->
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/autoSelectSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="自动选择"
                android:textSize="16sp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:minHeight="48dp" />

            <!-- Group 2: Features -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="功能"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="24dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginBottom="12dp" />

            <!-- Clipboard Sync -->
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/clipboardSyncSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="剪贴板同步"
                android:textSize="16sp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:minHeight="48dp"
                android:checked="true" />

            <!-- Notification Push -->
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/notificationSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="通知推送"
                android:textSize="16sp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:minHeight="48dp"
                android:checked="true" />

            <!-- Auto Update Check -->
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/autoUpdateSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="自动检查更新"
                android:textSize="16sp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:minHeight="48dp"
                android:checked="true" />

            <!-- Landscape Lock -->
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/landscapeLockSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="横屏锁定"
                android:textSize="16sp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:minHeight="48dp" />

            <!-- Group 3: Data Management -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="数据管理"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="24dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginBottom="12dp" />

            <!-- Save Settings (Dark) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveSettingsBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="保存设置"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"
                style="@style/Widget.MaterialComponents.Button"
                app:backgroundTint="#333333"
                android:textColor="#FFFFFF" />

            <!-- Clear Cache (Gray) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/clearCacheBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="清除缓存"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#9E9E9E"
                android:textColor="#9E9E9E" />

            <!-- Clear Cookies (Gray) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/clearCookiesBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="清除 Cookies"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#9E9E9E"
                android:textColor="#9E9E9E" />

            <!-- Clear All Data (Dark Red) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/clearAllDataBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="清除所有数据"
                android:textSize="16sp"
                android:layout_marginBottom="16dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#B71C1C"
                android:textColor="#B71C1C" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
